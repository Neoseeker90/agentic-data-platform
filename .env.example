# Database
POSTGRES_DB=agentdb
POSTGRES_USER=agent
POSTGRES_PASSWORD=changeme   # required — set a strong password, never commit the real value
DATABASE_URL=postgresql+asyncpg://agent:changeme@localhost:5432/agentdb

# LLM backend — set exactly ONE of the three options below:

# Option 1: Anthropic direct API
ANTHROPIC_API_KEY=

# Option 2: OpenAI (set key; change ROUTER_MODEL/PLANNING_MODEL/EXECUTION_MODEL to GPT model IDs)
OPENAI_API_KEY=

# Option 3: Amazon Bedrock (see section below)

# LLM — Amazon Bedrock (set CLAUDE_CODE_USE_BEDROCK=1 to enable; leave blank for direct API)
# When enabled, ANTHROPIC_API_KEY is ignored.
# Model IDs (ROUTER_MODEL, PLANNING_MODEL, EXECUTION_MODEL) are automatically mapped to
# Bedrock cross-region inference profile IDs for the configured AWS_REGION.
# You can also set them directly to a Bedrock model ARN (e.g. eu.anthropic.claude-3-5-haiku-20241022-v1:0).
CLAUDE_CODE_USE_BEDROCK=
AWS_REGION=eu-central-1
AWS_BEARER_TOKEN_BEDROCK=

# Object storage (LocalStack in dev, S3 in prod)
# Note: AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY below are for LocalStack S3 only.
# Bedrock auth uses AWS_BEARER_TOKEN_BEDROCK above, not these keys.
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_ARTIFACTS_BUCKET=agent-artifacts

# Lightdash
LIGHTDASH_URL=
LIGHTDASH_API_KEY=
LIGHTDASH_PROJECT_UUID=

# dbt
DBT_PROJECT_PATH=
DBT_TARGET_PATH=

# Router
CONFIDENCE_THRESHOLD=0.75
CLARIFICATION_THRESHOLD=0.50
ROUTER_MODEL=claude-3-5-haiku-20241022

# Skill execution
PLANNING_MODEL=claude-3-5-haiku-20241022
EXECUTION_MODEL=claude-3-5-sonnet-20241022

# App
ENVIRONMENT=development
LOG_LEVEL=INFO
